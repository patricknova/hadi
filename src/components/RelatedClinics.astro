---
import { supabase } from '../lib/supabase';

interface Props {
  specialtyTag: string;
}

const { specialtyTag } = Astro.props;

// Fetch 3 clinics matching the specialty
// We'll search for clinics whose 'specialites' array contains the tag (case-insensitive)
const { data: clinics } = await supabase
  .from('clinics_enriched')
  .select('nom, slug, rating, google_photos, quartier')
  .contains('specialites', [specialtyTag.toLowerCase()])
  .limit(3);

const googleApiKey = import.meta.env.GOOGLE_PLACES_API_KEY;
---

{clinics && clinics.length > 0 && (
  <div class="mt-16 bg-blue-50/50 rounded-3xl p-8 border border-blue-100">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Cliniques recommandées à Douala</h2>
      <span class="bg-blue-600 text-white text-[10px] px-3 py-1 rounded-full font-bold uppercase">
        {specialtyTag}
      </span>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {clinics.map((clinic) => (
        <a href={`/clinique/${clinic.slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition">
          <div class="aspect-video bg-gray-100 overflow-hidden">
            {clinic.google_photos && clinic.google_photos.length > 0 ? (
              <img 
                src={`https://places.googleapis.com/v1/${clinic.google_photos[0]}/media?key=${googleApiKey}&maxHeightPx=400`}
                alt={clinic.nom}
                class="w-full h-full object-cover group-hover:scale-110 transition duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-2xl">🏥</div>
            )}
          </div>
          <div class="p-4">
            <h3 class="font-bold text-gray-900 mb-1 group-hover:text-blue-600 transition truncate">{clinic.nom}</h3>
            <div class="flex items-center justify-between text-xs text-gray-500">
              <span class="flex items-center gap-1">📍 {clinic.quartier || 'Douala'}</span>
              {clinic.rating && <span class="text-amber-500 font-bold">⭐ {clinic.rating}</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="mt-8 text-center">
      <a href="/cliniques" class="text-blue-600 font-bold text-sm hover:underline">
        Voir toutes les cliniques spécialisées à Douala →
      </a>
    </div>
  </div>
)}
