---
import Layout from '../../layouts/Layout.astro';
import ClinicCard from '../../components/ClinicCard.astro';
import { supabase } from '../../lib/supabase';
import { slugify } from '../../lib/utils';

export const prerender = false;

const { slug } = Astro.params;

let clinics: any[] | null = [];
let quartierName = '';

try {
  // 1. Récupérer tous les quartiers uniques pour trouver celui qui correspond au slug
  const { data: allQuartiers } = await supabase.from('clinics_enriched').select('quartier');
  const uniqueQuartiers = [...new Set(allQuartiers?.map(q => q.quartier).filter(Boolean))];
  
  quartierName = uniqueQuartiers.find(q => slugify(q || '') === slug) || '';

  if (!quartierName) {
    return Astro.redirect('/404');
  }

  // 2. Fetch clinics for this specific quartier
  const { data, error } = await supabase
    .from('clinics_enriched')
    .select('*')
    .eq('quartier', quartierName)
    .order('nom', { ascending: true });

  if (error) throw error;
  clinics = data;
} catch (err) {
  console.error('Error fetching clinics for quartier:', err);
  return Astro.redirect('/404');
}
---

<Layout 
  title={`Cliniques à ${quartierName}`} 
  description={`Trouvez les meilleures cliniques à ${quartierName}, Douala — adresse, horaires et contacts sur Hadi.`}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-blue-600 transition">Accueil</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-gray-400">/</span>
            <span class="font-medium text-gray-800">Quartiers</span>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-gray-400">/</span>
            <span class="font-medium text-gray-800">{quartierName}</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
        Cliniques à <span class="text-blue-600">{quartierName}</span>
      </h1>
      <p class="text-lg text-gray-600 italic">
        Découvrez les {clinics?.length || 0} établissements de santé disponibles dans la zone de {quartierName}.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {clinics?.map((clinic) => (
        <ClinicCard clinic={clinic} />
      ))}
    </div>
    
    {clinics?.length === 0 && (
      <div class="text-center py-20 bg-gray-50 rounded-3xl border border-dashed border-gray-200">
        <p class="text-gray-500">Aucune clinique trouvée dans ce quartier pour le moment.</p>
      </div>
    )}
  </div>
</Layout>
