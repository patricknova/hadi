---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import RelatedClinics from '../../components/RelatedClinics.astro';

export const prerender = false;

const { slug } = Astro.params;

let post: any = null;

try {
  // Fetch full post data
  const { data, error } = await supabase
    .from('blog_posts')
    .select('*')
    .eq('slug', slug)
    .single();
  
  if (error || !data) throw new Error('Post not found');
  post = data;
} catch (err) {
  console.error('Error fetching post:', err);
  return Astro.redirect('/404');
}

// Pool d'images médicales ultra-fiables (Unsplash IDs simplifiés)
const imagePool = [
  "1505751172107-5962200a4883",
  "1512678080530-7760d81faba6",
  "1519494026892-80bbd2d6fd0d",
  "1538108149393-fdfd8169446d",
  "1551076805-e1869033e561",
  "1576091160550-2173bdd99611",
  "1584622650111-993a426fbf0a",
  "1502740479734-55023fe73c5b",
  "1526256262350-7da7584cf5eb",
  "1551601651-2a8555f1a136"
];

function getImageUrl(id: string, width = 1200) {
  const hash = id.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
  const index = hash % imagePool.length;
  const photoId = imagePool[index];
  return `https://images.unsplash.com/photo-${photoId}?auto=format&fit=crop&w=${width}&q=80`;
}
---

<Layout 
  title={`${post.title.substring(0, 50)} | Blog Santé Douala`}
  description={post.meta_description?.substring(0, 155) || post.excerpt?.substring(0, 155)}
>
  <script type="application/ld+json" slot="head" define:vars={{ post }}>
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt,
      "image": post.main_image,
      "datePublished": post.published_at,
      "author": {
        "@type": "Organization",
        "name": "Rédaction SantéDouala"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Hadi",
        "logo": {
          "@type": "ImageObject",
          "url": "https://hadi.cm/favicon.svg"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://hadi.cm/blog/${post.slug}`
      }
    }
  </script>

  <article class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-blue-600 transition">Accueil</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-gray-400">/</span>
            <a href="/blog" class="hover:text-blue-600 transition">Blog</a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-gray-400">/</span>
            <span class="font-medium text-gray-800 line-clamp-1">{post.title}</span>
          </div>
        </li>
      </ol>
    </nav>

    <header class="mb-12">
      <div class="aspect-video md:aspect-[21/9] rounded-3xl overflow-hidden mb-8 relative group shadow-2xl bg-gray-100">
        <img 
          src={post.main_image.startsWith('http') ? post.main_image : getImageUrl(post.id, 1200)} 
          alt={post.title}
          class="w-full h-full object-cover transition duration-700 group-hover:scale-105"
          loading="lazy"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
          onerror="this.onerror=null; this.src='https://loremflickr.com/1200/600/medical,africa';"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6 md:bottom-10 md:left-10 md:right-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-blue-600 text-white text-[10px] md:text-xs px-3 py-1 rounded-full font-bold uppercase tracking-wider shadow-lg">
              {post.specialty_tag || 'Santé'}
            </span>
            <span class="w-1.5 h-1.5 rounded-full bg-white/50"></span>
            <time class="text-xs md:text-sm font-bold text-gray-200 uppercase tracking-widest drop-shadow-md">
              {new Date(post.published_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
          </div>
          <h1 class="text-2xl md:text-5xl font-black text-white tracking-tight leading-tight drop-shadow-2xl max-w-4xl">
            {post.title}
          </h1>
        </div>
      </div>
      
      <div class="p-6 md:p-8 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-3xl border-l-8 border-blue-600 italic text-gray-700 text-lg shadow-sm">
        <span class="text-4xl text-blue-200 font-serif leading-none h-4 block mb-2">"</span>
        {post.excerpt}
      </div>
    </header>

    <div class="prose prose-lg prose-blue max-w-none text-gray-800 leading-relaxed 
                prose-headings:text-gray-900 prose-headings:font-extrabold 
                prose-p:mb-6 prose-ul:mb-6 prose-li:mb-2 prose-strong:text-blue-700">
      <Fragment set:html={post.content} />
    </div>

    <!-- Recommendations Synergy -->
    <RelatedClinics specialtyTag={post.specialty_tag} />

    <footer class="mt-16 pt-8 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-xl">✍️</div>
        <div>
          <p class="font-bold text-gray-900 leading-none">Rédaction SantéDouala</p>
          <p class="text-sm text-gray-500 mt-1">Écrit par nos experts médicaux locaux</p>
        </div>
      </div>
      
      <div class="flex gap-4">
        <button class="px-6 py-2 bg-gray-100 text-gray-700 rounded-xl font-bold text-sm hover:bg-gray-200 transition">
          Partager l'article
        </button>
      </div>
    </footer>
  </article>
</Layout>

<style is:global>
  /* Ensure the generated HTML content looks great */
  .prose h2 {
    font-size: 1.875rem;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: #111827;
  }
  .prose h3 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1a56a0;
  }
  .prose p {
    margin-bottom: 1.5rem;
  }
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .prose figure {
    margin: 3rem 0;
    text-align: center;
  }
  .prose img {
    border-radius: 1.5rem;
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
    margin: 0 auto;
    border: 1px solid #f3f4f6;
  }
  .prose figcaption {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: #6b7280;
    font-style: italic;
    font-weight: 500;
  }
</style>
