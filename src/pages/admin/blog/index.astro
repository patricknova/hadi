---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';

// Fetch all blog posts
const { data: posts, error } = await supabase
  .from('blog_posts')
  .select('id, title, slug, main_image, specialty_tag, published_at')
  .order('published_at', { ascending: false });

if (error) {
  console.error('Error fetching blog posts:', error);
}
---

<Layout title="Gestion du Blog - Hadi Admin">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/admin" class="hover:text-blue-600 transition tracking-tight font-medium">Dashboard Admin</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="mx-2 text-gray-400">/</span>
            <span class="font-medium text-gray-800">Gestion du Blog</span>
          </div>
        </li>
      </ol>
    </nav>

    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
        <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
          Gestion du <span class="text-blue-600">Blog</span>
        </h1>
        <p class="text-gray-500 mt-2 italic font-medium">Modifiez les images et les informations de vos articles.</p>
      </div>
    </header>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-gray-50 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">
              <th class="px-6 py-4">Article</th>
              <th class="px-6 py-4">Spécialité</th>
              <th class="px-6 py-4">Image Actuelle</th>
              <th class="px-6 py-4">Date de Publication</th>
              <th class="px-6 py-4">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-sm">
            {posts?.map((post) => (
              <tr class="hover:bg-gray-50 transition group">
                <td class="px-6 py-4">
                  <p class="font-bold text-gray-800 group-hover:text-blue-600 transition">{post.title}</p>
                  <p class="text-xs text-gray-400 italic">/{post.slug}</p>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded-md text-[10px] font-bold uppercase">
                    {post.specialty_tag}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="w-20 h-12 rounded-lg overflow-hidden bg-gray-100 border border-gray-200">
                    {post.main_image.startsWith('http') ? (
                      <img src={post.main_image} class="w-full h-full object-cover" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-[10px] text-gray-400 text-center px-1">
                        Mot-clé: {post.main_image}
                      </div>
                    )}
                  </div>
                </td>
                <td class="px-6 py-4 text-gray-500">
                  {new Date(post.published_at).toLocaleDateString('fr-FR')}
                </td>
                <td class="px-6 py-4">
                  <a 
                    href={`/admin/blog/edit?id=${post.id}`}
                    class="inline-flex items-center px-4 py-2 bg-blue-50 text-blue-600 rounded-xl font-bold text-xs hover:bg-blue-600 hover:text-white transition"
                  >
                    Modifier Image
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
